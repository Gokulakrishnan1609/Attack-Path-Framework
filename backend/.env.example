# ─────────────────────────────────────────
#  Attack Path Discovery — Environment Config
# ─────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Neo4j Connection (replace with your credentials)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Optional: NVD API Key (for live CVE lookups - leave empty to use local DB)
NVD_API_KEY=

# Scan settings
SCAN_TIMEOUT_MS=120000
MOCK_MODE=false
